{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CC1352P: Build SDK GCC libs",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-sdk-gcc.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Build rfDiagnostics AT",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-rfdiagnostics.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Build rfUARTBridge",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-rfuartbridge.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Build E79 AT modem",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-e79-at-modem.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash rfDiagnostics AT",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-rfdiagnostics.ps1"
            ],
            "dependsOn": "CC1352P: Build rfDiagnostics AT",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash rfUARTBridge",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-rfuartbridge.ps1"
            ],
            "dependsOn": "CC1352P: Build rfUARTBridge",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash E79 AT modem (J-Link recovery)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-e79-at-modem.ps1"
            ],
            "dependsOn": "CC1352P: Build E79 AT modem",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash E79 AT modem USB-UART manual BOOT",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-e79-at-modem-uart.ps1",
                "-Port",
                "${input:uartComPort}"
            ],
            "dependsOn": "CC1352P: Build E79 AT modem",
            "problemMatcher": []
        },
        {
            "label": "ESP32: Build CC1352P UART bridge",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build-esp32-cc1352-bridge.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "ESP32: Flash CC1352P UART bridge",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-esp32-cc1352-bridge.ps1",
                "-Port",
                "${input:esp32BridgeComPort}"
            ],
            "dependsOn": "ESP32: Build CC1352P UART bridge",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash E79 AT modem via ESP32 manual BOOT",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-e79-at-modem-via-esp32.ps1",
                "-Port",
                "${input:esp32BridgeComPort}"
            ],
            "dependsOn": "CC1352P: Build E79 AT modem",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Probe ESP32 BOOT+RESET bootloader entry",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/probe-e79-bootloader-auto-via-esp32.ps1",
                "-Port",
                "${input:esp32BridgeComPort}"
            ],
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Flash E79 AT modem via ESP32 (recommended)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/flash-e79-at-modem-via-esp32.ps1",
                "-Port",
                "${input:esp32BridgeComPort}",
                "-EnterBootloaderFromEsp32"
            ],
            "dependsOn": "CC1352P: Build E79 AT modem",
            "problemMatcher": []
        },
        {
            "label": "CC1352P: Test two E79 modules AT/RF",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/test-e79-at-rigorous-two-modules.ps1",
                "-PortA",
                "${input:e79PortA}",
                "-PortB",
                "${input:e79PortB}",
                "-BridgeBaud",
                "1000000"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "uartComPort",
            "type": "promptString",
            "description": "USB-UART COM port for CC1352P ROM bootloader, e.g. COM5"
        },
        {
            "id": "esp32BridgeComPort",
            "type": "promptString",
            "description": "ESP32-C3 native USB bridge COM port, e.g. COM19"
        },
        {
            "id": "e79PortA",
            "type": "promptString",
            "description": "First ESP32-C3 bridge COM port for E79 AT/RF tests",
            "default": "COM19"
        },
        {
            "id": "e79PortB",
            "type": "promptString",
            "description": "Second ESP32-C3 bridge COM port for E79 AT/RF tests",
            "default": "COM22"
        }
    ]
}
